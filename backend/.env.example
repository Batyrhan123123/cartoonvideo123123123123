# ============================================================
# amoCRM Integration — Environment Variables
# ============================================================
# Заполните эти переменные данными из вашего аккаунта amoCRM.
# После заполнения переименуйте файл в .env или добавьте
# переменные в настройки деплоя (Atoms Cloud Secrets).
# ============================================================

# Поддомен вашей amoCRM (то, что перед .amocrm.ru)
# Пример: если ваш URL — https://mycompany.amocrm.ru, то значение = mycompany
AMO_SUBDOMAIN=

# OAuth2 данные приложения (из раздела "Интеграции" в amoCRM)
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=

# Код авторизации (получается один раз при первом подключении)
AMO_AUTH_CODE=

# Токены доступа (access_token используется сервером для запросов к API)
# access_token истекает, refresh_token нужен для его обновления
AMO_ACCESS_TOKEN=
AMO_REFRESH_TOKEN=

# ID воронки (pipeline), в которую попадают новые заявки
# Найти: amoCRM → Сделки → Настройки воронки → URL содержит pipeline_id
AMO_PIPELINE_ID=

# ID этапа (status) внутри воронки для новых заявок
# Найти: amoCRM → Сделки → Настройки воронки → навести на этап
AMO_STATUS_ID=

# ID ответственного пользователя
# Найти: amoCRM → Настройки → Пользователи → кликнуть на пользователя → ID в URL
AMO_RESPONSIBLE_USER_ID=